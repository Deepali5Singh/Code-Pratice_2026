#include<stdio.h>

int main () {
int arr [5] = {1, 3, 5, 2, 2};
int leftsum;
int rightsum;
for (int i = 0 ; i < 5; i++)
{
leftsum = 0;
rightsum = 0;
for (int j = 0 ; j < i; j++){
leftsum = leftsum + arr[j];
}
for (int j = i+1 ; j < 5; j++){
rightsum = rightsum + arr[j];
if(leftsum == rightsum)
printf("%d", i + 1);
}
}
}


